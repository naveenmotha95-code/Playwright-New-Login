import { Page } from '@playwright/test';
import path from 'path';

const filePath = path.resolve(__dirname, '../TestImage.jpg');

export default class BuzzPage {
  readonly page: Page;
  readonly buzzLink;
  readonly shareBtn;
  readonly fileInput;
  readonly commentBox;
  readonly postBtn;
  readonly commentInput;
  readonly commentBtn;
  readonly editToggle;
  readonly editText;
  readonly saveBtn;

  constructor(page: Page) {
    this.page = page;

    this.buzzLink = page.locator('//span[text()="Buzz"]');
    this.shareBtn = page.locator('button:has-text("Share Photos")');
    this.fileInput = page.locator('input[type="file"]');
    this.commentBox = page.locator('textarea').first();
    this.postBtn = page.locator('button:has-text("Post")');

    this.commentInput = page.locator('textarea');
    this.commentBtn = page.locator('button:has-text("Comment")');

    this.editToggle = page.locator('.oxd-icon.bi-three-dots');
    this.editText = page.locator('textarea');
    this.saveBtn = page.locator('button:has-text("Save")');
  }

  async sharePhotoPost(comment: string) {
    await this.buzzLink.click();

    await this.page.waitForSelector('textarea');

    await this.shareBtn.click();

    await this.fileInput.setInputFiles(filePath);

    await this.commentBox.fill(comment);

    await this.postBtn.click();

    await this.page.waitForSelector('.oxd-toast-content');
  }

  async addCommentToPost(comment: string) {
    await this.buzzLink.click();

    await this.page.waitForSelector('textarea');

    await this.commentInput.first().fill(comment);

    await this.commentBtn.first().click();

    await this.page.waitForTimeout(2000);
  }

  async editPost(comment: string, editPostText: string) {
    await this.buzzLink.click();

    await this.page.waitForSelector('textarea');

    await this.shareBtn.click();
    await this.fileInput.setInputFiles(filePath);
    await this.commentBox.fill(comment);
    await this.postBtn.click();

    await this.page.waitForTimeout(3000);

    await this.editToggle.first().click();

    await this.editText.fill(editPostText);

    await this.saveBtn.click();

    await this.page.waitForSelector('.oxd-toast-content');
  }

  async mostcommentTab() {
    await this.buzzLink.click();
    await this.page.locator('//button[text()="Most Commented Posts"]').click();
  }
}


