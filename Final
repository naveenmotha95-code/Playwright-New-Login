import { Page } from '@playwright/test';

export default class AdminPage {
  readonly page: Page;
  readonly adminLink;
  readonly addBtn;
  readonly input;
  readonly saveBtn;
  readonly editBtn;
  readonly upgradeBtn;

  constructor(page: Page) {
    this.page = page;

    this.adminLink = page.locator('//span[text()="Admin"]');
    this.addBtn = page.locator('button:has-text("Add")');
    this.input = page.locator('input.oxd-input').nth(1);
    this.saveBtn = page.locator('button:has-text("Save")');
    this.editBtn = page.locator('.oxd-icon-button').first();
    this.upgradeBtn = page.locator('//button[text()="Upgrade"]');
  }

  async EditEmpStatus(name: string) {
    await this.adminLink.click();

    await this.page.locator('//span[text()="Job"]').click();
    await this.page.locator('//a[text()="Employment Status"]').click();

    await this.page.waitForSelector('.oxd-table');

    await this.editBtn.click();
    await this.input.fill(name);
    await this.saveBtn.click();
  }

  async AddEmpStatus(name: string) {
    await this.adminLink.click();

    await this.page.locator('//span[text()="Job"]').click();
    await this.page.locator('//a[text()="Employment Status"]').click();

    await this.addBtn.click();
    await this.input.fill(name);
    await this.saveBtn.click();
  }

  async adminModules() {
    await this.adminLink.click();

    await this.page.locator('//span[text()="Configuration"]').click();
    await this.page.locator('//a[text()="Modules"]').click();

    await this.page.waitForSelector('//h6[text()="Module Configuration"]');
  }

  async upgrade() {
    await this.adminLink.click();

    const [newPage] = await Promise.all([
      this.page.context().waitForEvent('page'),
      this.upgradeBtn.click()
    ]);

    await newPage.waitForLoadState();
  }
}

